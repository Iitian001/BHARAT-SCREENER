# Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Angel One API (Optional - for real-time data)
# Get your API key from: https://smartapi.angelbroking.com/
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PASSWORD=your_password_here

# Note: NSE India and Yahoo Finance work without API keys
